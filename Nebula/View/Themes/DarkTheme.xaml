<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Colors -->
    <Color x:Key="SideBarBackgroundColor">#FF232323</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="Purple" />
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#FF232323" />
    <SolidColorBrush x:Key="SecondaryAppBackgroundBrush" Color="#2A2A2A" />
    <SolidColorBrush x:Key="AppForegroundBrush" Color="White" />
    <SolidColorBrush x:Key="SideBarUsernameBrush" Color="White" />
    <SolidColorBrush x:Key="SideBarCategoryBrush" Color="#B5B5B5" />
    <SolidColorBrush x:Key="SideBarRadioButtonCheckedBrush" Color="White" />
    <SolidColorBrush x:Key="SideBarRadioButtonUnCheckedBrush" Color="#AFADAD" />
    <SolidColorBrush x:Key="SideBarRadioButtonLineBrush" Color="White" />
</ResourceDictionary>